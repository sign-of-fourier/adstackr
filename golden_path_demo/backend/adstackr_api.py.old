from fastapi import APIRouter, HTTPException
from typing import Dict, List
import logging
import uuid
import random

import httpx

from adstackr_models import (
    state,
    ConnectorConfig,
    RunState,
    MappingOption,
    get_or_create_option_stats,
)
from optimizer import optimize_run
from google_models import state as google_state

logger = logging.getLogger("adstackr_fake")

router = APIRouter()


@router.post("/connect", response_model=ConnectorConfig)
async def connect(cfg: ConnectorConfig):
    state.connector_configs[cfg.tenant_id] = cfg

    # simulate ingestion: call Google Fake APIs via real HTTP
    async with httpx.AsyncClient() as client:
        base = "http://localhost:8000/google"
        logger.info(
            "AdStackr -> GoogleFake: GET /studio/templates",
            extra={"tenant_id": cfg.tenant_id},
        )
        templates_resp = await client.get(f"{base}/studio/templates")
        logger.info(
            "AdStackr -> GoogleFake: GET /studio/feeds",
            extra={"tenant_id": cfg.tenant_id},
        )
        feeds_resp = await client.get(f"{base}/studio/feeds")
        logger.info(
            "AdStackr -> GoogleFake: GET /dv360/lineItems",
            extra={"tenant_id": cfg.tenant_id},
        )
        li_resp = await client.get(f"{base}/dv360/lineItems")
        logger.info(
            "AdStackr -> GoogleFake: GET /dv360/creatives",
            extra={"tenant_id": cfg.tenant_id},
        )
        cr_resp = await client.get(f"{base}/dv360/creatives")

        templates_resp.raise_for_status()
        feeds_resp.raise_for_status()
        li_resp.raise_for_status()
        cr_resp.raise_for_status()

    return cfg


@router.get("/catalog")
async def catalog(tenant_id: str) -> Dict:
    cfg = state.connector_configs.get(tenant_id)
    if not cfg:
        raise HTTPException(status_code=404, detail="Unknown tenant")

    return {
        "campaigns": list(google_state.campaigns.values()),
        "line_items": list(google_state.line_items.values()),
        "creatives": list(google_state.creatives.values()),
        "templates": list(google_state.templates.values()),
        "feed_rows": list(google_state.feed_rows.values()),
    }


@router.post("/sim/start")
async def sim_start(tenant_id: str) -> Dict[str, str]:
    if tenant_id not in state.connector_configs:
        raise HTTPException(status_code=404, detail="Unknown tenant")

    run_id = str(uuid.uuid4())

    # build trivial candidates from GoogleFake templates + feed rows
    candidates: Dict[str, List[str]] = {}
    mapping_options: Dict[str, MappingOption] = {}

    for feed in google_state.feed_rows.values():
        segment_id = feed.segment_id
        candidates.setdefault(segment_id, [])
        for template in google_state.templates.values():
            option_key = f"{segment_id}__{template.id}"
            candidates[segment_id].append(option_key)
            mapping_options[option_key] = MappingOption(
                segment_id=segment_id,
                template_id=template.id,
                component_variants=feed.data,
            )

    run = RunState(
        run_id=run_id,
        tenant_id=tenant_id,
        candidates=candidates,
        mapping_options=mapping_options,
    )

    # initial random choice per segment
    for segment_id, option_keys in candidates.items():
        if option_keys:
            run.current_choice[segment_id] = random.choice(option_keys)

    state.runs[run_id] = run

    logger.info("AdStackr sim_start", extra={"run_id": run_id, "tenant_id": tenant_id})
    return {"run_id": run_id}


@router.post("/sim/step")
async def sim_step(run_id: str, n: int = 1) -> Dict[str, int]:
    run = state.runs.get(run_id)
    if not run:
        raise HTTPException(status_code=404, detail="Unknown run")

    total_imps = 0
    total_clicks = 0
    total_convs = 0

    for _ in range(n):
        # pick a segment uniformly
        if not run.current_choice:
            break
        segment_id = random.choice(list(run.current_choice.keys()))
        option_key = run.current_choice[segment_id]
        opt = run.mapping_options[option_key]

        # pick some fake ids for line item and creative
        if not google_state.line_items or not google_state.creatives:
            continue
        li = random.choice(list(google_state.line_items.values()))
        cr = random.choice(list(google_state.creatives.values()))

        stats = get_or_create_option_stats(run, segment_id, option_key)
        stats.impressions += 1
        total_imps += 1

        # random click and conversion
        if random.random() < 0.05:
            stats.clicks += 1
            total_clicks += 1
            if random.random() < 0.2:
                stats.conversions += 1
                total_convs += 1

    logger.info(
        "AdStackr sim_step",
        extra={
            "run_id": run_id,
            "impressions": total_imps,
            "clicks": total_clicks,
            "conversions": total_convs,
        },
    )

    return {
        "impressions": total_imps,
        "clicks": total_clicks,
        "conversions": total_convs,
    }


@router.post("/optimize")
async def optimize(run_id: str) -> Dict[str, Dict[str, str]]:
    run = state.runs.get(run_id)
    if not run:
        raise HTTPException(status_code=404, detail="Unknown run")

    new_choices = optimize_run(run)
    logger.info(
        "AdStackr optimize",
        extra={"run_id": run_id, "segments": list(new_choices.keys())},
    )

    # return a human-readable view
    response: Dict[str, Dict[str, str]] = {}
    for segment_id, option_key in new_choices.items():
        opt = run.mapping_options[option_key]
        response[segment_id] = {
            "template_id": opt.template_id,
            "component_variants": str(opt.component_variants),
        }

    return response


@router.get("/sim/{run_id}/status")
async def sim_status(run_id: str) -> List[Dict[str, str]]:
    run = state.runs.get(run_id)
    if not run:
        raise HTTPException(status_code=404, detail="Unknown run")

    rows: List[Dict[str, str]] = []
    for (segment_id, option_key), stats in run.stats.items():
        opt = run.mapping_options[option_key]
        rows.append(
            {
                "segment_id": segment_id,
                "template_id": opt.template_id,
                "impressions": stats.impressions,
                "clicks": stats.clicks,
                "conversions": stats.conversions,
            }
        )

    return rows

